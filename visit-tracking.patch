+
+function _checkContactUpdate(caseId, selVal, customName, phone) {
+  var c = cases.find(function(x){ return x.id === caseId; });
+  if (!c) return;
+  var contacts = Array.isArray(c.contacts) ? c.contacts : [];
+  if (selVal === '__custom__' && customName) {
+    openContactUpdateModal(caseId, {name: customName, relation: '', phone: phone, isNew: true});
+    return;
+  }
+  if (selVal && selVal !== '__custom__' && phone) {
+    var ct = contacts.find(function(ct) {
+      var label = ct.relation ? ct.relation + '-' + ct.name : ct.name;
+      return label === selVal || ct.name === selVal;
+    });
+    if (ct && ct.phone !== phone) {
+      openContactUpdateModal(caseId, {name: ct.name, relation: ct.relation || '', phone: phone, isNew: false});
+    } else if (!ct && phone) {
+      openContactUpdateModal(caseId, {name: selVal, relation: '', phone: phone, isNew: true});
+    }
+  }
+}
+
+var _contactUpdateCaseId = null;
+var _contactUpdateIsNew = false;
+var _contactUpdateOrigName = null;
+
+function openContactUpdateModal(caseId, contact) {
+  _contactUpdateCaseId = caseId;
+  _contactUpdateIsNew = !!contact.isNew;
+  _contactUpdateOrigName = contact.name;
+  var c = cases.find(function(x){ return x.id === caseId; });
+  var caseName = c ? c.name : caseId;
+  var msgEl = document.getElementById('contact-update-msg');
+  if (msgEl) {
+    msgEl.innerHTML = _contactUpdateIsNew
+      ? '📌 電訪中使用了新的聯繫對象，是否將 <b>「' + contact.name + '」</b> 加入個案 <b>' + caseName + '</b> 的聯繫資料？<br><span style="font-size:12px;color:var(--text3)">加入後下次電訪可直接從下拉選單選取</span>'
+      : '📝 電訪中記錄的電話與個案資料不同，是否更新 <b>「' + contact.name + '」</b> 的聯繫電話？';
+  }
+  document.getElementById('cu-name').value = contact.name || '';
+  document.getElementById('cu-relation').value = contact.relation || '';
+  document.getElementById('cu-phone').value = contact.phone || '';
+  document.getElementById('contact-update-modal').classList.remove('hidden');
+}
+
+function saveContactUpdate() {
+  var name = document.getElementById('cu-name').value.trim();
+  if (!name) { alert('請填入姓名'); return; }
+  var relation = document.getElementById('cu-relation').value.trim();
+  var phone = document.getElementById('cu-phone').value.trim();
+  var cIdx = cases.findIndex(function(x){ return x.id === _contactUpdateCaseId; });
+  if (cIdx < 0) { document.getElementById('contact-update-modal').classList.add('hidden'); return; }
+  var contacts = Array.isArray(cases[cIdx].contacts) ? cases[cIdx].contacts.slice() : [];
+  if (_contactUpdateIsNew) {
+    contacts.push({name: name, relation: relation, phone: phone});
+  } else {
+    var ci = contacts.findIndex(function(ct){ return ct.name === _contactUpdateOrigName; });
+    if (ci >= 0) {
+      contacts[ci] = {name: name, relation: relation, phone: phone};
+    } else {
+      contacts.push({name: name, relation: relation, phone: phone});
+    }
+  }
+  cases[cIdx].contacts = contacts;
+  saveData('cases', cases);
+  document.getElementById('contact-update-modal').classList.add('hidden');
+  alert('✅ 聯繫資料已更新至個案「' + (cases[cIdx].name || _contactUpdateCaseId) + '」');
 }
 
